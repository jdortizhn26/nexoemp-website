# ─────────────────────────────────────────────────────────────────────────────
# LA MAR — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copia este archivo y renómbralo a: .env.local
# 2. Llena cada variable con los valores de tu proyecto Firebase:
#    Firebase Console → Configuración del proyecto → Tus apps → SDK config
# 3. En Vercel: Settings → Environment Variables → agrega cada una
# 4. NUNCA subas .env.local a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=AIzaSy...tu-api-key...
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
